{
  "version": 2,
  "buildCommand": "npm install && npx prisma generate --schema=./prisma/schema.prisma && npm run build && cd backend && npm install",
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/src/index.ts"
    },
    {
      "src": "^/(.*)",
      "dest": "frontend/dist/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": ".*",
      "dest": "frontend/dist/index.html"
    }
  ]
}
